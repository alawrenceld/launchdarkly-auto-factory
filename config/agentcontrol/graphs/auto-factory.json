{
  "key": "gha-auto-factory",
  "name": "GHA AutoFactory",
  "description": "Agent graph that represents the chain of agents in the GHA version of AutoFactory",
  "rootConfigKey": "autofactory-research-planner",
  "edges": [
    {
      "key": "edge-autofactory-research-planner-autofactory-manifest-steward",
      "sourceConfig": "autofactory-research-planner",
      "targetConfig": "autofactory-manifest-steward",
      "handoff": {
        "max_turns": 8,
        "request_type": "Fix",
        "capabilities": [
          "steward_manifest"
        ],
        "skip_if_tags": {
          "skip_flagging": "true"
        }
      }
    },
    {
      "key": "edge-autofactory-manifest-steward-autofactory-flag-implementer",
      "sourceConfig": "autofactory-manifest-steward",
      "targetConfig": "autofactory-flag-implementer",
      "handoff": {
        "max_turns": 20,
        "request_type": "Fix",
        "capabilities": [
          "create_flag",
          "edit_files",
          "write_manifest"
        ]
      }
    },
    {
      "key": "edge-autofactory-flag-testing-autofactory-code-reviewer",
      "sourceConfig": "autofactory-flag-testing",
      "targetConfig": "autofactory-code-reviewer",
      "handoff": {
        "max_turns": 30,
        "request_type": "Fix"
      }
    },
    {
      "key": "edge-autofactory-metrics-author-autofactory-flag-testing",
      "sourceConfig": "autofactory-metrics-author",
      "targetConfig": "autofactory-flag-testing",
      "handoff": {
        "max_turns": 20,
        "request_type": "Fix",
        "capabilities": [
          "edit_files"
        ],
        "require_tags": {
          "needs_tests": "true"
        }
      }
    },
    {
      "key": "edge-autofactory-flag-implementer-autofactory-metrics-author",
      "sourceConfig": "autofactory-flag-implementer",
      "targetConfig": "autofactory-metrics-author",
      "handoff": {
        "max_turns": 20,
        "request_type": "Fix",
        "capabilities": [
          "create_metric",
          "edit_files",
          "write_manifest"
        ],
        "require_tags": {
          "flag_created": "true"
        }
      }
    }
  ]
}
