{
  "name": "launchdarkly-auto-factory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Autonomous, safe software releases using LaunchDarkly (prototype).",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --pretty && tsc -p tests --noEmit",
    "clean": "tsc --build --clean",
    "check:public": "node scripts/check-public.mjs",
    "check:configs": "node scripts/check-configs.mjs",
    "test": "node --import tsx --test tests/*.test.ts",
    "bootstrap": "node bootstrap/create.mjs",
    "bridge": "node --import tsx packages/config-bridge/src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.0",
    "typescript": "^5.6.0"
  }
}
