# Copy to .env and fill in. NEVER commit real values (.env is gitignored).
# This file documents the SHAPE of required secrets only.

# --- LaunchDarkly: target (the env the running prototype draws from) ---
# API token with write access to flags, metrics, and AI/agent configs.
LD_API_TOKEN=
# REST API base URL. Default is production; the LD-internal instance uses a
# different (non-production) base URL — see config/ld-targets.yaml.
LD_API_BASE_URL=https://app.launchdarkly.com
LD_PROJECT_KEY=
LD_ENVIRONMENT_KEY=

# --- LaunchDarkly: source (for the bridge's `sync`, if pulling configs) ---
# Optional. Only needed when refreshing local canonical copies from a source
# instance (LD team -> internal instance; customers normally skip this).
LD_SOURCE_API_TOKEN=
LD_SOURCE_API_BASE_URL=

# --- GitHub (Phase 1 GitHub Action) ---
GITHUB_TOKEN=

# --- Railway (Phase 2 CD) ---
RAILWAY_TOKEN=

# --- Beacon (Phase 2 orchestrator) ---
# Shared secret the Notifier uses to authenticate POSTs to Beacon.
BEACON_WEBHOOK_SECRET=
